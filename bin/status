#!/usr/bin/env bash
set -euo pipefail

# Derive workspace from this script's location:
#   bin/status -> agent-system/bin/status -> workspace is two levels up
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENT_SYSTEM_DIR="$(dirname "$SCRIPT_DIR")"
WORKSPACE="$(dirname "$AGENT_SYSTEM_DIR")"

# shellcheck source=../lib/agent-session.sh
source "${AGENT_SYSTEM_DIR}/lib/agent-session.sh"

# --- Colors ---
COLOR_YELLOW='\033[0;33m'
COLOR_GREEN='\033[0;32m'
COLOR_DIM='\033[2m'
COLOR_RESET='\033[0m'
COLOR_BOLD='\033[1m'

# --- Human-readable relative time ---
relative_time() {
    local ts="$1"
    local label="$2"
    if [[ -z "$ts" || "$ts" == "0" ]]; then
        echo ""
        return
    fi
    local now
    now=$(date +%s)
    local diff=$(( now - ts ))

    if (( diff < 60 )); then
        echo "${label} ${diff}s ago"
    elif (( diff < 3600 )); then
        echo "${label} $(( diff / 60 ))m ago"
    elif (( diff < 86400 )); then
        echo "${label} $(( diff / 3600 ))h ago"
    else
        echo "${label} $(( diff / 86400 ))d ago"
    fi
}

# --- Collect sessions ---
found=0
declare -a rows=()

while IFS= read -r -d '' session_file; do
    dir="$(dirname "$session_file")"
    dir_name="$(basename "$dir")"

    # Read session data
    eval "$(read_agent_session "$dir")" 2>/dev/null || continue

    state="${SESSION_state:-cloned}"
    agent="${SESSION_agent:-}"
    pid="${SESSION_pid:-}"
    started_at="${SESSION_started_at:-}"
    finished_at="${SESSION_finished_at:-}"

    # --- Crash recovery: check stale PID ---
    display_state="$state"
    if [[ "$state" == "running" && -n "$pid" ]]; then
        if ! is_pid_alive "$pid"; then
            display_state="done (interrupted)"
        fi
    fi

    # --- Agent label ---
    agent_label="--"
    if [[ -n "$agent" ]]; then
        agent_label="$(echo "$agent" | tr '[:lower:]' '[:upper:]')"
    fi

    # --- Commits ahead of main ---
    commits_ahead="?"
    if [[ -d "${dir}/.git" ]]; then
        commits_ahead=$(git -C "$dir" rev-list --count origin/main..HEAD 2>/dev/null || echo "?")
    fi

    # --- Time context ---
    time_ctx=""
    case "$display_state" in
        running)
            time_ctx="$(relative_time "$started_at" "started")"
            ;;
        done|interrupted|"done (interrupted)")
            if [[ -n "$finished_at" && "$finished_at" != "0" ]]; then
                time_ctx="$(relative_time "$finished_at" "finished")"
            else
                time_ctx="$(relative_time "$started_at" "started")"
            fi
            ;;
        cloned)
            time_ctx="$(relative_time "$started_at" "cloned")"
            ;;
    esac

    # Store row data
    rows+=("${dir_name}|${agent_label}|${display_state}|${commits_ahead} ahead|${time_ctx}")
    found=1

done < <(find "$WORKSPACE" -maxdepth 2 -name "$AGENT_SESSION_FILE" -print0 2>/dev/null | sort -z)

if (( found == 0 )); then
    echo "No active features found in ${WORKSPACE}"
    exit 0
fi

# --- Print header ---
printf "\n${COLOR_BOLD}ACTIVE FEATURES${COLOR_RESET}\n"

# --- Print rows ---
for row in "${rows[@]}"; do
    IFS='|' read -r dir_name agent_label display_state commits time_ctx <<< "$row"

    # Pick color based on state
    color="$COLOR_RESET"
    case "$display_state" in
        running)                color="$COLOR_YELLOW" ;;
        interrupted|"done (interrupted)")  color="$COLOR_YELLOW" ;;
        done*)                  color="$COLOR_GREEN" ;;
        cloned)                 color="$COLOR_DIM" ;;
    esac

    printf "  ${color}%-35s %-8s %-20s %-12s %s${COLOR_RESET}\n" \
        "$dir_name" "$agent_label" "$display_state" "$commits" "$time_ctx"
done
printf "\n"
